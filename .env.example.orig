# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=nfe
DB_PASSWORD=nfe123
DB_NAME=nfe_db
DB_SSLMODE=disable

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=nfe_queue

# Server
SERVER_PORT=8080

# Quarantine — failed NF-es are automatically deleted after this many days
QUARANTINE_TTL_DAYS=30
QUARANTINE_CLEANUP_INTERVAL_HOURS=24
