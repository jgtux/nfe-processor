+// isXMLContent performs a cheap pre-check on file content before enqueuing.
+// It avoids persisting and enqueuing obvious non-XML files.
+func isXMLContent(data []byte) bool {
+	trimmed := bytes.TrimSpace(data)
+	return bytes.HasPrefix(trimmed, []byte("<?xml")) ||
+		bytes.HasPrefix(trimmed, []byte("<nfeProc"))
+}
